# XLM SAC address on testnet
NEXT_PUBLIC_XLM_SAC=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCN4

# APY in basis points (1200 = 12%)
NEXT_PUBLIC_APY_BPS=1200
